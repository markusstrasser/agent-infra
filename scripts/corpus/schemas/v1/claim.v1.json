{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.local/corpus/claim/v1.0.0",
  "title": "claim (per-repo MCP return contract)",
  "description": "Shape per-repo MCPs (genomics-mcp, phenome-mcp, intel-mcp) MUST return from claims_for_source(source_id). Domain semantics differ; this is the wire shape.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "claim_id", "repo", "predicate", "asserted_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "1-0-0"},
    "claim_id": {"type": "string", "minLength": 1},
    "repo": {
      "type": "string",
      "enum": ["genomics", "phenome", "intel"]
    },
    "predicate": {"type": "string", "minLength": 1},
    "predicate_family": {"type": ["string", "null"]},
    "slots": {
      "type": "object",
      "description": "Per-claim slot payload. Domain-specific; opaque at this layer."
    },
    "entities": {
      "type": "array",
      "items": {"type": "object"}
    },
    "asserted_at": {"type": "string", "format": "date-time"},
    "valid_time_start": {"type": ["string", "null"]},
    "valid_time_end": {"type": ["string", "null"]},
    "status": {
      "type": ["string", "null"],
      "enum": [null, "active", "superseded", "retracted"]
    }
  }
}
