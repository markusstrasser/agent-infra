{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.local/corpus/source-record/v1.0.0",
  "title": "corpus source_record (metadata.json)",
  "description": "Per-source metadata.json schema. Intrinsic facts only — RO-Crate JSON-LD shell is generated at export time (Phase 8), not stamped at ingest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "source_type",
    "content_hash",
    "retrieved_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1-0-0"
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "paper",
        "preprint",
        "database_release",
        "regulatory_filing",
        "tool_output",
        "webpage",
        "blog_post",
        "news",
        "other"
      ]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{16,64}$",
      "description": "Authoritative sha256 of source bytes (PDF for paper, HTML for webpage, etc.)."
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "doi": {"type": ["string", "null"]},
    "pmid": {"type": ["string", "null"]},
    "pmcid": {"type": ["string", "null"]},
    "title": {"type": ["string", "null"]},
    "authors": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "year": {"type": ["integer", "null"]},
    "parsed_sha256": {"type": ["string", "null"], "pattern": "^([0-9a-f]{16,64})?$"},
    "pdf_sha256": {"type": ["string", "null"], "pattern": "^([0-9a-f]{16,64})?$"},
    "retraction_status": {
      "type": ["string", "null"],
      "enum": [null, "unknown", "active", "retracted", "expression_of_concern", "corrected"]
    },
    "fabio_class": {"type": ["string", "null"]},
    "wikidata_qid": {"type": ["string", "null"]},
    "openalex_id": {"type": ["string", "null"]},
    "parser": {"type": ["object", "null"]},
    "revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["retired_at", "prior_pdf_sha256"],
        "properties": {
          "retired_at": {"type": "string", "format": "date-time"},
          "prior_pdf_sha256": {"type": "string"},
          "prior_parsed_sha256": {"type": ["string", "null"]},
          "prior_parser_id": {"type": ["string", "null"]}
        }
      }
    },
    "last_updated": {"type": ["string", "null"]},
    "corpus:source_type": {"type": "string"},
    "corpus:source_id": {"type": "string"},
    "corpus:content_hash": {"type": "string"}
  }
}
