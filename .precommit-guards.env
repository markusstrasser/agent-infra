# Sourced by skills/hooks/pre-commit-guards.sh (the .git/hooks/pre-commit dispatcher).
# Tool-agnostic enforcement that holds under Codex too (Claude PreToolUse Write|Edit
# guards do not reliably fire under Codex — see decisions/2026-06-02-codex-cli-project-parity.md §FINAL).

# Append-only: improvement-log.md and decisions/ may only grow (block shrink/delete).
# Mirrors the Claude PreToolUse append-only guard in .claude/settings.json.
PRECOMMIT_APPENDONLY_PATHS='(^|/)improvement-log\.md$|^decisions/'

# Read-only data paths (none in agent-infra; data repos set this to their raw-data dirs).
PRECOMMIT_PROTECTED_PATHS=''
